# Copy this file to .env and fill in real values. Do NOT commit .env.

# Server
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/asalpasal

# Email (nodemailer)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Khalti Payment
KHALTI_SECRET_KEY=your_khalti_secret_key
KHALTI_API_URL=https://a.khalti.com/api/v2

# PayPal Payment
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# Python ML recommender microservice (see ml-service/)
RECOMMENDER_URL=http://localhost:8000
